# ─────────────────────────────────────────────────────────────
# AbirOS environment — copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
API_PORT=4000
WEB_PORT=5173
APP_BASE_URL=http://localhost:5173

# Auth (single user)
AUTH_USERNAME=abir
AUTH_PASSWORD_HASH=            # bcrypt hash — run `pnpm setup:password` to generate
JWT_SECRET=change_me_to_a_long_random_string
COOKIE_SECURE=false

# Database (Neon free tier — see README §Neon)
# Pooled string (host contains "-pooler") — used at runtime by the app.
DATABASE_URL=
# Direct/unpooled string — used ONLY by drizzle-kit migrations + enable-vector.
DIRECT_DATABASE_URL=
# Both must include ?sslmode=require

# AI providers
LLM_PROVIDER=ollama            # ollama | openai_compatible | anthropic
EMBEDDING_PROVIDER=ollama      # ollama | openai_compatible
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768
# Optional hosted fallbacks (leave blank to keep everything free/local)
OPENAI_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./data/files

# Integrations (optional, supplied later — Phase 2)
GITHUB_TOKEN=
